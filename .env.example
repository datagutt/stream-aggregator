# StreamAggregator Environment Configuration
# Copy this file to .env and fill in your values
# Usage: cp .env.example .env

# ============================================================================
# Server Configuration
# ============================================================================

# Server host (0.0.0.0 for Docker, 127.0.0.1 for local)
HOST=0.0.0.0

# Server port
PORT=8080

# Log level: trace, debug, info, warn, error
RUST_LOG=info

# ============================================================================
# Storage Configuration
# ============================================================================

# Storage backend (always use "diesel" for production)
STORE_BACKEND=diesel

# Database URL - path to SQLite database file
# For Docker: /data/streams.db (persisted in volume)
# For local: ./data/streams.db (or any path)
DATABASE_URL=/data/streams.db

# ============================================================================
# Authentication (Optional)
# ============================================================================

# API keys for authentication (comma-separated)
# Generate secure keys: openssl rand -hex 32
# Leave empty to disable authentication
API_KEYS=

# Require authentication for ALL requests (including GET /streams)
# false = Public read access, auth only for writes (default)
# true = All endpoints require authentication
REQUIRE_AUTH_ALL=false

# ============================================================================
# Scheduler Configuration
# ============================================================================

# Scrape interval in seconds (default: 300 = 5 minutes)
SCRAPE_INTERVAL_SECS=300

# ============================================================================
# Provider Configuration
# ============================================================================

# --- Twitch ---
# Get credentials at: https://dev.twitch.tv/console/apps
# Required for Twitch provider to work
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- Other Providers ---
# YouTube, Kick, DLive, Trovo, etc. work without credentials
# Enable/disable in config.toml if needed
